# SmartPI Dashboard — Configuration
# Copier ce fichier : cp .env.example .env
# Puis remplir les valeurs ci-dessous.

# URL du serveur Home Assistant
HA_URL=http://homeassistant.local:8123

# Long-Lived Access Token HA
# (Profil → Sécurité → Jetons d'accès à longue durée de vie)
HA_TOKEN=

# Entité climate Versatile Thermostat à superviser
CLIMATE_ENTITY=climate.thermostat

# Port du serveur Flask (défaut : 5000)
FLASK_PORT=5000

# Clé secrète Flask (générée aléatoirement si absente)
# python3 -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=
